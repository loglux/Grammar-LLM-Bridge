# Grammar-LLM-Bridge — example environment file
#
# Copy this file to deploy/load-balancer/.env.bridge and fill in your values.
# Never commit the populated file. The Bridge reads these at container start
# via env_file in deploy/load-balancer/docker-compose.yml.

# ─── LLM backend (required) ────────────────────────────────────────────────
# Any OpenAI-compatible API works: OpenAI, DeepSeek, OpenRouter, Ollama, ...
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com           # or https://api.openai.com/v1
LLM_MODEL=deepseek-chat                            # or gpt-4.1-mini, deepseek-v4-flash, etc.

# ─── Behaviour flags ──────────────────────────────────────────────────────
GRAMMAR_ONLY=false           # true → suppress style/wordiness/awkward suggestions
TYPOGRAPHY_CHECK=false       # true → also report typographic issues
LLM_TIMEOUT=120              # seconds before giving up on a single LLM call

# ─── Chunking (long texts get split before LLM call) ───────────────────────
LLM_CHUNKING=true
LLM_CHUNK_SIZE=600           # target chunk size in characters
LLM_CHUNK_OVERLAP=60         # overlap to preserve context across boundaries
LLM_CHUNK_THRESHOLD=1200     # only chunk if text is longer than this
LLM_CHUNK_STRATEGY=paragraph # "paragraph" (legacy) or "recursive" (LaTeX-safe,
                             # splits inside paragraphs by sentence; reduces
                             # context-induced false positives)

# ─── Database (auth/users; optional, defaults to local SQLite) ────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/grammar_llm_bridge.db
